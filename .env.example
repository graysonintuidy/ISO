# ============================================================
# National Beef AI Monitor — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Vantage API Configuration
VANTAGE_API_KEY=your_vantage_api_key_here
VANTAGE_API_BASE=https://vantage.intuidy.com/api/v1/

# Vantage Workflow IDs (set after creating workflows)
VANTAGE_DB_QUERY_WORKFLOW_ID=
VANTAGE_DB_WRITE_WORKFLOW_ID=
VANTAGE_CHAT_WORKFLOW_ID=

# Intuidy Managed Database
DB_HOST=db.intuidy.com
DB_PORT=3306
DB_NAME=your_database_name_here
DB_SSL=required

# Application
NEXT_PUBLIC_APP_NAME=National Beef AI Monitor
NEXT_PUBLIC_DEFAULT_FACILITY=kck

# Auth
JWT_SECRET=generate-a-secure-random-string-here
SESSION_DURATION_HOURS=24
